<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Agent Radar · 项目库</title>
<style>
:root {
  --bg: #0d1117; --surface: #161b22; --border: #30363d;
  --text: #e6edf3; --muted: #8b949e; --accent: #58a6ff;
  --green: #3fb950; --red: #f85149; --yellow: #d29922;
  --tag-bg: #1f2937; --tag-border: #374151;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--bg); color: var(--text); font-family: -apple-system, "Segoe UI", sans-serif; font-size: 14px; }

/* ── Header ─────────────────────────────────────────── */
header {
  background: var(--surface); border-bottom: 1px solid var(--border);
  padding: 16px 24px; display: flex; align-items: center; gap: 20px; flex-wrap: wrap;
}
header h1 { font-size: 18px; font-weight: 600; }
header h1 span { color: var(--accent); }
header .sub { color: var(--muted); font-size: 13px; }
header .back-link { margin-left: auto; color: var(--accent); text-decoration: none; font-size: 13px; white-space: nowrap; }
header .back-link:hover { text-decoration: underline; }

/* ── Controls ───────────────────────────────────────── */
.controls {
  padding: 16px 24px; background: var(--surface); border-bottom: 1px solid var(--border);
  display: flex; gap: 12px; flex-wrap: wrap; align-items: center;
}
.search-wrap { position: relative; flex: 1; min-width: 200px; max-width: 400px; }
.search-wrap input {
  width: 100%; background: var(--bg); border: 1px solid var(--border); border-radius: 6px;
  padding: 7px 10px 7px 32px; color: var(--text); font-size: 13px; outline: none;
}
.search-wrap input:focus { border-color: var(--accent); }
.search-icon { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--muted); }
.domain-filter { display: flex; gap: 6px; flex-wrap: wrap; }
.domain-btn {
  background: var(--tag-bg); border: 1px solid var(--tag-border); color: var(--muted);
  border-radius: 20px; padding: 4px 10px; font-size: 12px; cursor: pointer; white-space: nowrap;
  transition: all .15s;
}
.domain-btn:hover, .domain-btn.active {
  background: var(--accent); border-color: var(--accent); color: #fff;
}
.sort-wrap { display: flex; gap: 6px; }
.sort-btn {
  background: var(--tag-bg); border: 1px solid var(--tag-border); color: var(--muted);
  border-radius: 6px; padding: 5px 10px; font-size: 12px; cursor: pointer;
  transition: all .15s;
}
.sort-btn:hover { color: var(--text); }
.sort-btn.active { border-color: var(--accent); color: var(--accent); }
.stat { color: var(--muted); font-size: 12px; margin-left: auto; white-space: nowrap; }

/* ── Table ──────────────────────────────────────────── */
.table-wrap { overflow-x: auto; padding: 0 24px 40px; }
table { width: 100%; border-collapse: collapse; margin-top: 16px; }
thead th {
  text-align: left; padding: 8px 12px; font-size: 12px; font-weight: 600;
  color: var(--muted); text-transform: uppercase; letter-spacing: .04em;
  border-bottom: 1px solid var(--border); white-space: nowrap;
}
tbody tr { border-bottom: 1px solid var(--border); transition: background .1s; }
tbody tr:hover { background: var(--surface); }
td { padding: 10px 12px; vertical-align: middle; }

/* columns */
.col-id    { width: 90px; font-family: monospace; }
.col-repo  { min-width: 220px; }
.col-domain{ min-width: 160px; }
.col-stars { width: 100px; text-align: right; }
.col-delta { width: 80px; text-align: right; }
.col-lang  { width: 90px; }
.col-date  { width: 80px; white-space: nowrap; }
.col-desc  { min-width: 260px; color: var(--muted); font-size: 13px; }

/* ar-id badge */
.ar-badge {
  display: inline-block; background: #1a2233; border: 1px solid #2d4a7a;
  color: var(--accent); border-radius: 4px; padding: 2px 6px;
  font-size: 11px; font-family: monospace; letter-spacing: .02em; white-space: nowrap;
}
.repo-link { color: var(--text); text-decoration: none; font-weight: 500; font-size: 13px; }
.repo-link:hover { color: var(--accent); text-decoration: underline; }
.repo-owner { color: var(--muted); font-weight: 400; }

.tag {
  display: inline-block; background: var(--tag-bg); border: 1px solid var(--tag-border);
  color: #9ca3af; border-radius: 20px; padding: 2px 8px; font-size: 11px;
  margin: 2px 2px 2px 0; white-space: nowrap;
}

.stars-val { font-variant-numeric: tabular-nums; }
.delta-up   { color: var(--green); font-size: 12px; }
.delta-down { color: var(--red);   font-size: 12px; }
.delta-flat { color: var(--muted); font-size: 12px; }

.lang-dot {
  display: inline-block; width: 10px; height: 10px; border-radius: 50%;
  background: #4b5563; margin-right: 5px; vertical-align: middle;
}
.lang-label { font-size: 12px; color: var(--muted); }

.desc-text { overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }

/* hide rows via JS */
tr.hidden { display: none; }

/* ── Footer ─────────────────────────────────────────── */
footer { text-align: center; color: var(--muted); font-size: 12px; padding: 24px; border-top: 1px solid var(--border); }
</style>
</head>
<body>

<header>
  <div>
    <h1>Agent Radar · <span>项目库</span></h1>
    <div class="sub">共追踪 <strong>{{ total }}</strong> 个开源项目 · 每周自动更新 · {{ generated_at }}</div>
  </div>
  <a class="back-link" href="/agent-radar/">← 返回周报</a>
</header>

<div class="controls">
  <div class="search-wrap">
    <span class="search-icon">🔍</span>
    <input id="search" type="text" placeholder="搜索项目名称 / 描述…" oninput="applyFilter()">
  </div>
  <div class="domain-filter">
    <button class="domain-btn active" data-domain="all" onclick="setDomain('all',this)">全部</button>
    {% for domain_id, meta in domain_meta.items() %}
    <button class="domain-btn" data-domain="{{ domain_id }}" onclick="setDomain('{{ domain_id }}',this)">{{ meta.name }}</button>
    {% endfor %}
  </div>
  <div class="sort-wrap">
    <button class="sort-btn active" id="sort-ar" onclick="sortBy('ar',this)">编号</button>
    <button class="sort-btn" id="sort-stars" onclick="sortBy('stars',this)">Stars ↓</button>
    <button class="sort-btn" id="sort-delta" onclick="sortBy('delta',this)">本周涨幅</button>
    <button class="sort-btn" id="sort-date" onclick="sortBy('date',this)">首次入库</button>
  </div>
  <div class="stat" id="stat">显示 {{ total }} / {{ total }}</div>
</div>

<div class="table-wrap">
<table id="proj-table">
<thead>
  <tr>
    <th class="col-id">编号</th>
    <th class="col-repo">项目</th>
    <th class="col-domain">领域</th>
    <th class="col-stars">Stars</th>
    <th class="col-delta">本周±</th>
    <th class="col-lang">语言</th>
    <th class="col-date">首次入库</th>
    <th class="col-desc">简介</th>
  </tr>
</thead>
<tbody id="tbody">
{% for p in projects %}
<tr data-ar="{{ p.ar_id }}"
    data-stars="{{ p.stars }}"
    data-delta="{{ p.delta_stars }}"
    data-date="{{ p.first_seen }}"
    data-domains="{{ p.domain_ids | join(' ') }}"
    data-search="{{ p.ar_id }} {{ p.repo }} {{ p.description | lower }}">
  <td class="col-id"><span class="ar-badge">{{ p.ar_id }}</span></td>
  <td class="col-repo">
    <a class="repo-link" href="{{ p.repo_url }}" target="_blank" rel="noopener">
      <span class="repo-owner">{{ p.repo.split('/')[0] }}/</span>{{ p.repo.split('/')[1] }}
    </a>
  </td>
  <td class="col-domain">
    {% for name in p.domain_names %}<span class="tag">{{ name }}</span>{% endfor %}
  </td>
  <td class="col-stars">
    <span class="stars-val">{{ "{:,}".format(p.stars) }}</span>
  </td>
  <td class="col-delta">
    {% if p.delta_stars > 0 %}
      <span class="delta-up">+{{ "{:,}".format(p.delta_abs) }}</span>
    {% elif p.delta_stars < 0 %}
      <span class="delta-down">−{{ "{:,}".format(p.delta_abs) }}</span>
    {% else %}
      <span class="delta-flat">—</span>
    {% endif %}
  </td>
  <td class="col-lang">
    {% if p.language %}
    <span class="lang-dot"></span><span class="lang-label">{{ p.language }}</span>
    {% endif %}
  </td>
  <td class="col-date">{{ p.first_seen }}</td>
  <td class="col-desc"><div class="desc-text">{{ p.description }}</div></td>
</tr>
{% endfor %}
</tbody>
</table>
</div>

<footer>Agent Radar · 数据来源 GitHub API · 每周一 01:00 UTC 自动更新</footer>

<script>
let activeDomain = 'all';
let activeSort   = 'ar';

function setDomain(domain, btn) {
  activeDomain = domain;
  document.querySelectorAll('.domain-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  applyFilter();
}

function sortBy(key, btn) {
  activeSort = key;
  document.querySelectorAll('.sort-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  applyFilter();
}

function applyFilter() {
  const q = document.getElementById('search').value.trim().toLowerCase();
  const tbody = document.getElementById('tbody');
  const rows = Array.from(tbody.querySelectorAll('tr'));

  // filter
  rows.forEach(row => {
    const matchDomain = activeDomain === 'all' || row.dataset.domains.split(' ').includes(activeDomain);
    const matchSearch = !q || row.dataset.search.includes(q);
    row.classList.toggle('hidden', !(matchDomain && matchSearch));
  });

  // sort visible rows
  const visible = rows.filter(r => !r.classList.contains('hidden'));
  visible.sort((a, b) => {
    if (activeSort === 'stars') return parseInt(b.dataset.stars) - parseInt(a.dataset.stars);
    if (activeSort === 'delta') return parseInt(b.dataset.delta) - parseInt(a.dataset.delta);
    if (activeSort === 'date')  return b.dataset.date.localeCompare(a.dataset.date);
    // 'ar': numeric sort by AR-XXXX
    return parseInt(a.dataset.ar.slice(3)) - parseInt(b.dataset.ar.slice(3));
  });
  visible.forEach(r => tbody.appendChild(r));

  // update stat
  document.getElementById('stat').textContent =
    `显示 ${visible.length} / {{ total }}`;
}
</script>
</body>
</html>
